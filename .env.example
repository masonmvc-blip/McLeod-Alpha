# Morning CIO Gmail SMTP configuration. Copy required values into .env.
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=
EMAIL_TO=
EMAIL_FROM_NAME=McLeod Alpha
EXPECTED_EMAIL_ADDRESS=

# Production defaults: Gmail SMTP only, strict recommendation gating.
MORNING_CIO_REQUIRE_SMTP_ONLY=true
MORNING_CIO_STRICT_RECOMMENDATIONS=true
MORNING_CIO_MAX_RESEARCH_AGE_HOURS=48
