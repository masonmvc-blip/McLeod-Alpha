  "scoring_rules": {
    "mcleod_core_composite": {
      "description": "Only calculate when sufficient data available",
      "required_fields": [
        "valuation",
        "business_quality",
        "balance_sheet",
        "roic"
      ],
      "minimum_quality_threshold": 50,
      "weights": {
        "valuation": 0.25,
        "business_quality": 0.35,
        "balance_sheet": 0.15,
        "capital_allocation": 0.15,
        "roic": 0.1
      },
      "note": "If any required field is NEEDS_RESEARCH, score is NOT assigned"
    }
  },
